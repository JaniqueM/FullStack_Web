{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "momo_sms_db-schemas",
  "title": "MoMo SMS Data Processing System – JSON Schemas & Examples",
  "description": "JSON schemas and representative API response examples for all entities in momo_sms_db",
  "version": "1.0.0",
  "schemas": {
    "TransactionCategory": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TransactionCategory",
      "description": "A lookup record describing a class of MoMo transaction",
      "type": "object",
      "required": [
        "category_id",
        "category_name",
        "category_code",
        "is_credit"
      ],
      "properties": {
        "category_id": {
          "type": "integer",
          "minimum": 1,
          "description": "Auto-increment PK"
        },
        "category_name": {
          "type": "string",
          "maxLength": 100,
          "description": "Human-readable label"
        },
        "category_code": {
          "type": "string",
          "maxLength": 30,
          "description": "Short machine-readable code"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "is_credit": {
          "type": "boolean",
          "description": "true = money in, false = money out"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "description": "An account holder, counterparty, agent, or merchant referenced in SMS messages",
      "type": "object",
      "required": [
        "user_id",
        "full_name",
        "user_type",
        "is_active"
      ],
      "properties": {
        "user_id": {
          "type": "integer",
          "minimum": 1
        },
        "full_name": {
          "type": "string",
          "maxLength": 150
        },
        "phone_number": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 20
        },
        "account_number": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 20
        },
        "user_type": {
          "type": "string",
          "enum": [
            "ACCOUNT_HOLDER",
            "COUNTERPARTY",
            "AGENT",
            "MERCHANT"
          ]
        },
        "is_active": {
          "type": "boolean"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "Tag": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tag",
      "description": "A descriptive label that can be applied to one or more transactions",
      "type": "object",
      "required": [
        "tag_id",
        "tag_name"
      ],
      "properties": {
        "tag_id": {
          "type": "integer",
          "minimum": 1
        },
        "tag_name": {
          "type": "string",
          "maxLength": 80
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "description": "One financial event parsed from a MoMo SMS message",
      "type": "object",
      "required": [
        "transaction_id",
        "category_id",
        "amount",
        "fee",
        "currency",
        "transaction_date",
        "sms_date",
        "raw_sms_body",
        "status"
      ],
      "properties": {
        "transaction_id": {
          "type": "integer"
        },
        "financial_tx_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 50
        },
        "external_tx_id": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 50
        },
        "category_id": {
          "type": "integer"
        },
        "sender_id": {
          "type": [
            "integer",
            "null"
          ]
        },
        "receiver_id": {
          "type": [
            "integer",
            "null"
          ]
        },
        "amount": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "fee": {
          "type": "number",
          "minimum": 0
        },
        "balance_after": {
          "type": [
            "number",
            "null"
          ]
        },
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3,
          "default": "RWF"
        },
        "transaction_date": {
          "type": "string",
          "format": "date-time"
        },
        "sms_date": {
          "type": "integer",
          "description": "Unix timestamp in milliseconds"
        },
        "raw_sms_body": {
          "type": "string"
        },
        "service_center": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 20
        },
        "status": {
          "type": "string",
          "enum": [
            "SUCCESS",
            "FAILED",
            "PENDING"
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "SystemLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SystemLog",
      "description": "An audit or debug log entry from a processing pipeline",
      "type": "object",
      "required": [
        "log_id",
        "log_level",
        "event_type",
        "message",
        "created_at"
      ],
      "properties": {
        "log_id": {
          "type": "integer"
        },
        "log_level": {
          "type": "string",
          "enum": [
            "INFO",
            "WARNING",
            "ERROR",
            "DEBUG"
          ]
        },
        "event_type": {
          "type": "string",
          "maxLength": 80
        },
        "transaction_id": {
          "type": [
            "integer",
            "null"
          ]
        },
        "message": {
          "type": "string"
        },
        "stack_trace": {
          "type": [
            "string",
            "null"
          ]
        },
        "ip_address": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 45
        },
        "process_name": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 100
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "TransactionTag": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TransactionTag",
      "description": "Junction record linking a transaction to a tag (M:N bridge)",
      "type": "object",
      "required": [
        "transaction_id",
        "tag_id",
        "assigned_at"
      ],
      "properties": {
        "transaction_id": {
          "type": "integer"
        },
        "tag_id": {
          "type": "integer"
        },
        "assigned_at": {
          "type": "string",
          "format": "date-time"
        },
        "assigned_by": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 80
        }
      },
      "additionalProperties": false
    }
  },
